# Application
APP_PORT=8080
JAVA_OPTS=-Xms256m -Xmx768m

# MySQL
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=zhiguang_auth
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/zhiguang_auth?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me

# Redis
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=change-me

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Elasticsearch
SPRING_ELASTICSEARCH_URIS=http://elasticsearch:9200
SPRING_ELASTICSEARCH_USERNAME=elastic
SPRING_ELASTICSEARCH_PASSWORD=change-me
SPRING_AI_VECTORSTORE_ELASTICSEARCH_INDEX_NAME=zhiguang-ai-index

# MinIO / OSS
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_DOMAIN=http://your-server-ip:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=zhiguang

# Spring AI chat / embedding
SPRING_AI_OPENAI_CHAT_BASE_URL=https://your-openai-compatible-gateway
SPRING_AI_OPENAI_CHAT_API_KEY=change-me
SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=gpt-4o-mini
SPRING_AI_OPENAI_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
SPRING_AI_OPENAI_EMBEDDING_API_KEY=change-me
SPRING_AI_OPENAI_EMBEDDING_OPTIONS_MODEL=text-embedding-v4
SPRING_AI_OPENAI_EMBEDDING_OPTIONS_DIMENSIONS=1536

# Rerank
RAG_RERANK_ENABLED=true
RAG_RERANK_BASE_URL=https://ai.api.nvidia.com
RAG_RERANK_API_KEY=change-me
RAG_RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2
RAG_RERANK_PATH=/v1/retrieval/nvidia/llama-nemotron-rerank-1b-v2/reranking

# Canal, optional for local compose unless a canal container/service is configured
CANAL_ENABLED=false
CANAL_HOST=canal
CANAL_PORT=11111
CANAL_DESTINATION=example
CANAL_USERNAME=canal
CANAL_PASSWORD=change-me
